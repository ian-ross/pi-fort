{
  "name": "pi-fort",
  "version": "0.3.1",
  "description": "VM-isolated sandbox for pi with automatic secret protection",
  "author": "mgabor3141",
  "license": "MIT",
  "repository": {
    "url": "git+https://github.com/ian-ross/pi-fort.git"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "yapp"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates",
    "containers",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:container": "make -C containers pi-work",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "pi": {
    "extensions": [
      "dist/index.js"
    ]
  },
  "dependencies": {
    "@earendil-works/gondolin": "^0.10.0",
    "graphql": "^16.14.0",
    "smol-toml": "^1.6.1",
    "valibot": "^1.4.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@earendil-works/pi-coding-agent": "^0.74.1",
    "@types/node": "^25.8.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@10.33.2"
}
